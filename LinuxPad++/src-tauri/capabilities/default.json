{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "urls": ["https://**", "http://**", "mailto:**"] }]
    }
  ]
}
